@model IEnumerable<GLMS.Web.Models.Contract>
@{
    ViewData["Title"] = "Contracts";
}

<h2>Contracts</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Add Contract</a>

<!-- Search/Filter Form -->
<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label class="form-label">Start Date (From)</label>
        <input type="date" name="startDate" class="form-control"
               value="@ViewBag.StartDate" />
    </div>
    <div class="col-md-3">
        <label class="form-label">End Date (To)</label>
        <input type="date" name="endDate" class="form-control"
               value="@ViewBag.EndDate" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            <option value="">-- All --</option>
            @foreach (var s in (System.Array)ViewBag.Statuses)
            {
                <option value="@s" selected="@(ViewBag.SelectedStatus?.ToString() == s.ToString())">
                    @s
                </option>
            }
        </select>
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-info me-2">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Client</th>
            <th>Service Level</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Signed Agreement</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contract in Model)
        {
            <tr>
                <td>@contract.Client?.Name</td>
                <td>@contract.ServiceLevel</td>
                <td>@contract.StartDate.ToString("dd MMM yyyy")</td>
                <td>@contract.EndDate.ToString("dd MMM yyyy")</td>
                <td>
                    <span class="badge
                        @(contract.Status == GLMS.Web.Models.ContractStatus.Active
                                                      ? "bg-success"
                                                      : contract.Status == GLMS.Web.Models.ContractStatus.Expired
                                                          ? "bg-danger"
                                                          : contract.Status == GLMS.Web.Models.ContractStatus.OnHold
                                                              ? "bg-warning text-dark"
                                                              : "bg-secondary")">
                        @contract.Status
                    </span>
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                    {
                        <a href="@contract.SignedAgreementPath"
                               target="_blank" class="btn btn-sm btn-outline-primary">
                            Download PDF
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">None</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@contract.ContractId"
                       class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@contract.ContractId"
                       class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>