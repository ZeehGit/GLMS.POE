@model GLMS.Web.Models.Contract
@{
    ViewData["Title"] = "Add Contract";
}

<h2>Add Contract</h2>
<div class="col-md-6">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="ClientId" class="form-label">Client</label>
            <select asp-for="ClientId" asp-items="ViewBag.Clients"
                    class="form-select">
                <option value="">-- Select Client --</option>
            </select>
            <span asp-validation-for="ClientId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status"
                    asp-items="Html.GetEnumSelectList<GLMS.Web.Models.ContractStatus>()"
                    class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="ServiceLevel" class="form-label"></label>
            <input asp-for="ServiceLevel" class="form-control" />
            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Signed Agreement (PDF only)</label>
            <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>