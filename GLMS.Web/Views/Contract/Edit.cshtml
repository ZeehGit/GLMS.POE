@model GLMS.Web.Models.Contract
@{
    ViewData["Title"] = "Edit Contract";
}

<h2>Edit Contract</h2>
<div class="col-md-6">
    <form asp-action="Edit" enctype="multipart/form-data">
        <input type="hidden" asp-for="ContractId" />
        <input type="hidden" asp-for="SignedAgreementPath" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="ClientId" class="form-label">Client</label>
            <select asp-for="ClientId" asp-items="ViewBag.Clients"
                    class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status"
                    asp-items="Html.GetEnumSelectList<GLMS.Web.Models.ContractStatus>()"
                    class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="ServiceLevel" class="form-label"></label>
            <input asp-for="ServiceLevel" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Replace PDF (optional)</label>
            <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <small class="text-muted">
                    Current: <a href="@Model.SignedAgreementPath" target="_blank">View PDF</a>
                </small>
            }
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>