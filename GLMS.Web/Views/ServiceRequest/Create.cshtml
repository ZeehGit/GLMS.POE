@model GLMS.Web.Models.ServiceRequest
@{
    ViewData["Title"] = "New Service Request";
}

<h2>New Service Request</h2>

@if (ViewBag.RateError != null)
{
    <div class="alert alert-warning">@ViewBag.RateError</div>
}
else
{
    <div class="alert alert-info">
        Current USD → ZAR Rate: <strong>@ViewBag.CurrentRate</strong>
    </div>
}

<div class="col-md-6">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="ContractId" class="form-label">Contract (Active only)</label>
            <select asp-for="ContractId" asp-items="ViewBag.Contracts"
                    class="form-select">
                <option value="">-- Select Contract --</option>
            </select>
            <span asp-validation-for="ContractId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CostUSD" class="form-label">Cost (USD)</label>
            <input asp-for="CostUSD" type="number" step="0.01"
                   class="form-control" />
            <span asp-validation-for="CostUSD" class="text-danger"></span>
            <small class="text-muted">
                ZAR cost will be auto-calculated on save.
            </small>
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status"
                    asp-items="Html.GetEnumSelectList<GLMS.Web.Models.ServiceRequestStatus>()"
                    class="form-select"></select>
        </div>

        <button type="submit" class="btn btn-primary">Submit Request</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>